  <diagram id="data_flow" name="Data Flow">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- 标题 -->
        <mxCell id="title2" value="典型建模流程 &amp; 数据流向" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="760" height="40" as="geometry" />
        </mxCell>

        <!-- 步骤 1 -->
        <mxCell id="step1" value="1. 数据获取&#xa;━━━━━━━━━━━━━&#xa;• generate_random_data&#xa;• query_clickhouse&#xa;• query_mysql&#xa;• query_hive&#xa;• upload_file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebc;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- 箭头 1-2 -->
        <mxCell id="arrow_1_2" value="CSV/Excel" style="endArrow=classic;html=1;strokeColor=#666666;strokeWidth=2;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="180" y="220" as="sourcePoint" />
            <mxPoint x="180" y="280" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 步骤 2 -->
        <mxCell id="step2" value="2. 数据探索&#xa;━━━━━━━━━━━━━&#xa;• descriptive_statistics&#xa;• single_column_analysis&#xa;• 数据质量检查&#xa;• 分布分析" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="200" height="120" as="geometry" />
        </mxCell>

        <!-- 箭头 2-3 -->
        <mxCell id="arrow_2_3" value="分析报告" style="endArrow=classic;html=1;strokeColor=#666666;strokeWidth=2;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="180" y="400" as="sourcePoint" />
            <mxPoint x="180" y="460" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 步骤 3 -->
        <mxCell id="step3" value="3. 特征工程&#xa;━━━━━━━━━━━━━&#xa;• create_bins_report (分箱)&#xa;• transform_to_woe (WOE)&#xa;• feature_selection (选择)&#xa;• encode_features (编码)&#xa;• get_psi_report (PSI)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="200" height="140" as="geometry" />
        </mxCell>

        <!-- 箭头 3-4 -->
        <mxCell id="arrow_3_4" value="处理后的数据" style="endArrow=classic;html=1;strokeColor=#666666;strokeWidth=2;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="280" y="530" as="sourcePoint" />
            <mxPoint x="420" y="530" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 步骤 4 -->
        <mxCell id="step4" value="4. 模型训练&#xa;━━━━━━━━━━━━━&#xa;• train_binary_model&#xa;  - LR / XGBoost / LightGBM&#xa;  - MLP / SVM / RandomForest&#xa;• pca_analysis (降维)&#xa;• kmeans_clustering (聚类)&#xa;• linear_regression (回归)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="420" y="460" width="220" height="140" as="geometry" />
        </mxCell>

        <!-- 箭头 4-5 -->
        <mxCell id="arrow_4_5" value="模型文件" style="endArrow=classic;html=1;strokeColor=#666666;strokeWidth=2;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="530" y="400" as="sourcePoint" />
            <mxPoint x="530" y="340" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 步骤 5 -->
        <mxCell id="step5" value="5. 模型评估&#xa;━━━━━━━━━━━━━&#xa;• generate_model_report&#xa;• AUC/KS/LIFT 指标&#xa;• 混淆矩阵&#xa;• 评分分箱报告" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="420" y="220" width="220" height="110" as="geometry" />
        </mxCell>

        <!-- 箭头 5-6 -->
        <mxCell id="arrow_5_6" value="评估报告" style="endArrow=classic;html=1;strokeColor=#666666;strokeWidth=2;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="530" y="220" as="sourcePoint" />
            <mxPoint x="530" y="150" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- 步骤 6 -->
        <mxCell id="step6" value="6. 结果输出&#xa;━━━━━━━━━━━━━&#xa;• download_file (下载)&#xa;• save_to_hive (入库)&#xa;• execute_linux_command&#xa;• 报告文件 (Excel/PNG)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebc;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="220" height="110" as="geometry" />
        </mxCell>

        <!-- 输出文件说明 -->
        <mxCell id="output_files" value="输出文件类型&#xa;━━━━━━━━━━━━━━━━━━━━━━━&#xa;• Excel 报告: WOE/IV/PSI/模型评估&#xa;• 模型文件: .pkl/.h5&#xa;• 图表: KS/AUC/LIFT 曲线 (.png)&#xa;• 数据: CSV/JSON&#xa;• SQL: 建表语句" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="250" height="150" as="geometry" />
        </mxCell>

        <!-- 工具选择指南 -->
        <mxCell id="tool_guide" value="工具选择建议&#xa;━━━━━━━━━━━━━━━━━━━━━━━&#xa;1. 优先使用专用 cbhpacks 工具 (25个)&#xa;   → 参数优化，自动保存报告&#xa;&#xa;2. 定制化分析用 execute_code_tool&#xa;   → 直接调用 cbhpacks 模块&#xa;&#xa;3. 辅助工具: 文件/包管理/健康检查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="700" y="280" width="250" height="180" as="geometry" />
        </mxCell>

        <!-- 访问方式 -->
        <mxCell id="access_methods" value="客户端访问方式&#xa;━━━━━━━━━━━━━━━━━━━━━━━&#xa;• MCP 协议: call_tool('工具名', {参数})&#xa;• HTTP API: POST /execute {code: ...}&#xa;• 文件上传: POST /upload (multipart)&#xa;• 文件下载: GET /download/{filepath}&#xa;• Jupyter: 浏览器交互开发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="700" y="500" width="250" height="180" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
